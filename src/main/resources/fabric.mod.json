{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "name": "${mod_name}",
  "version": "${mod_version}",
  "description": "${mod_description}",
  "authors": [
    "${mod_author}"
  ],
  "contact": {
    "homepage": "https://github.com/Ivan-Khar/${mod_name}",
    "sources": "https://github.com/Ivan-Khar/${mod_name}",
    "issues": "https://github.com/Ivan-Khar/${mod_name}/issues"
  },
  "icon": "assets/${mod_id}/icon.png",
  "license": "${mod_license}",
  "environment": "*",
  "entrypoints": {
    "main": [
      {
        "adapter": "kotlin",
        "value": "one.theaq.template.platform.fabric.FabricEntrypoint"
      }
    ],
    "client": [
      {
        "adapter": "kotlin",
        "value": "one.theaq.template.client.platform.fabric.FabricClientEntrypoint"
      }
    ]
  },
  "accessWidener": "${minecraft_version}.accesswidener",
  "depends": {
    "minecraft": "~${minecraft_version}",
    "fabric-api": "*",
    "fabricloader": ">=0.17.0"
  }
}